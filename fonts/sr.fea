      lookup calt_n_ri;
      lookup calt_n_rn;
      lookup calt_n_ra;
      lookup calt_a_li;
      lookup calt_a_ri;
      lookup calt_a_rn;
      lookup calt_a_ra;

 script latn;
    language dflt ;
      lookup calt_i_li_ri;
      lookup calt_i_li_rn;
      lookup calt_i_li_ra;
      lookup calt_n_li_ri;
      lookup calt_n_li_rn;
      lookup calt_n_li_ra;
      lookup calt_a_li_ri;
      lookup calt_a_li_rn;
      lookup calt_a_li_ra;
      lookup calt_i_li;
      lookup calt_i_ri;
      lookup calt_i_rn;
      lookup calt_i_ra;
      lookup calt_n_li;
      lookup calt_n_ri;
      lookup calt_n_rn;
      lookup calt_n_ra;
      lookup calt_a_li;
      lookup calt_a_ri;
      lookup calt_a_rn;
      lookup calt_a_ra;
} calt;


