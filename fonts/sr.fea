feature calt {
 script DFLT;
    language dflt ;
      lookup calt_i_li_ri;
      lookup calt_i_li_rn;
      lookup calt_i_li_ra;
      lookup calt_n_li_ri;
      lookup calt_n_li_rn;
      lookup calt_n_li_ra;
      lookup calt_a_li_ri;
      lookup calt_a_li_rn;
      lookup calt_a_li_ra;
      lookup calt_i_li;
      lookup calt_i_ri;
      lookup calt_i_rn;
