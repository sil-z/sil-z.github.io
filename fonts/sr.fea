languagesystem DFLT dflt;
languagesystem latn dflt;

@_li = [\i \i.li \i.ri \i.li.ri \i.li.rn \i.rn \i.ra \i.li.ra \n \n.li \n.ri \n.li.ri \n.rn \n.li.rn \n.ra \n.li.ra \a \a.li \a.ri \a.ra \a.rn \a.li.ri \a.li.ra \a.li.rn ];
@_ri = [\i \i.li \i.ri \i.li.ri \i.li.rn \i.rn \i.ra \i.li.ra ];
@_rn = [\n \n.li \n.ri \n.li.ri \n.rn \n.li.rn \n.ra \n.li.ra ];
@_ra = [\a \a.li \a.ri \a.ra \a.rn \a.li.ri \a.li.ra \a.li.rn ];

lookup calt_i_li_ri {
  lookupflag 0;
    @cc1_match_1 = [\i ];
    sub @_li @cc1_match_1' @_ri  by [\i.li.ri ] ;
} calt_i_li_ri;

lookup calt_i_li_rn {
  lookupflag 0;
    @cc1_match_1 = [\i ];
    sub @_li @cc1_match_1' @_rn  by [\i.li.rn ] ;
}calt_i_li_rn;

